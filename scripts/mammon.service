[Unit]
Description=MAMMON Autonomous Yield Optimizer
Documentation=https://github.com/kpjmd/Mammon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
# The live droplet deploy is a git checkout at /root/mammon (NOT the abandoned
# /opt/mammon rsync copy). Must match it so pydantic-settings finds .env and the
# app resolves data/ (DB, heartbeat).
WorkingDirectory=/root/mammon
Environment="PYTHONUNBUFFERED=1"
Environment="PATH=/root/.local/bin:/usr/local/bin:/usr/bin:/bin"
# --duration 744 = 31 days (margin over the 30-day validation). Restart=always
# is the real survivability guarantee: it restarts on BOTH a crash (non-zero)
# and a clean exit at end_time, and after a droplet reboot. Restart is safe —
# the circuit breaker persists to disk (data/circuit_breaker_state.json) and the
# loop reconciles positions from on-chain state at each cycle start.
ExecStart=/root/.local/bin/poetry run python -u scripts/run_autonomous_optimizer.py --duration 744 --interval 2
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mammon

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
